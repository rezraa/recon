# Docker Compose (default)
DATABASE_URL=postgresql://recon:recon@postgres:5432/recon
REDIS_URL=redis://redis:6379
# Local development (without Docker)
# DATABASE_URL=postgresql://recon:recon@localhost:5432/recon
# REDIS_URL=redis://localhost:6379
# Encryption key for API key storage — Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
# Optional: path to a custom GGUF model for LLM scoring (default: models/Qwen3.5-2B-Q4_K_M.gguf)
# LLM_MODEL_PATH=
# SearXNG URL for company intelligence (default: http://searxng:8080 in Docker)
# SEARXNG_URL=http://searxng:8080
# Company intelligence cache TTL in days (default: 7)
# COMPANY_INTEL_TTL_DAYS=7
# SearXNG rate limit in milliseconds between requests (default: 3000)
# SEARXNG_RATE_LIMIT_MS=3000
