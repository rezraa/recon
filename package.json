{
  "name": "recon",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:dev": "tsx src/worker/index.ts",
    "worker:build": "tsc -p tsconfig.worker.json && tsc-alias -p tsconfig.worker.json",
    "ci": "pnpm lint && pnpm tsc --noEmit && pnpm tsc --noEmit -p tsconfig.worker.json && pnpm drizzle-kit check && pnpm vitest run && pnpm next build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@nivo/radar": "^0.99.0",
    "bullmq": "^5.70.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "framer-motion": "^12.35.0",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pdf-parse": "1.1.1",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "playwright": "^1.58.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
